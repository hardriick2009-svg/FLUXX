    <script>
        // --- CHERRY BLOSSOM SIMULATION ENGINE ---
        const canvas = document.getElementById('canvas-ambient-tether');
        const ctx = canvas.getContext('2d');
        let flowerArray = [];
        let globalScaleFactor = window.devicePixelRatio || 1;

        function configureCanvasDimensions() {
            canvas.width = window.innerWidth * globalScaleFactor;
            canvas.height = window.innerHeight * globalScaleFactor;
            canvas.style.width = `${window.innerWidth}px`;
            canvas.style.height = `${window.innerHeight}px`;
            ctx.scale(globalScaleFactor, globalScaleFactor);
        }
        window.addEventListener('resize', () => { configureCanvasDimensions(); generateFlowerMatrix(); });
        configureCanvasDimensions();

        class CherryBlossomPetal {
            constructor() { this.resetProperties(true); }
            resetProperties(initiallyOffscreen = false) {
                this.x = Math.random() * window.innerWidth;
                this.y = initiallyOffscreen ? Math.random() * -window.innerHeight : -20;
                this.size = Math.random() * 5 + 5;
                this.speedY = Math.random() * 0.9 + 0.6;
                this.speedX = Math.random() * 0.6 - 0.3;
                this.rotationAngle = Math.random() * Math.PI * 2;
                this.rotationVelocity = Math.random() * 0.012 - 0.006;
                this.swayOscillator = Math.random() * Math.PI;
                this.swaySpeed = Math.random() * 0.015 + 0.01;
                this.color = `rgba(255, ${Math.floor(Math.random() * 25 + 185)}, ${Math.floor(Math.random() * 20 + 205)}, ${Math.random() * 0.3 + 0.35})`;
            }
            update() {
                this.y += this.speedY;
                this.swayOscillator += this.swaySpeed;
                this.x += this.speedX + Math.sin(this.swayOscillator) * 0.25;
                this.rotationAngle += this.rotationVelocity;
                if (this.y > window.innerHeight + 20 || this.x < -20 || this.x > window.innerWidth + 20) this.resetProperties(false);
            }
            draw() {
                ctx.save(); ctx.translate(this.x, this.y); ctx.rotate(this.rotationAngle); ctx.fillStyle = this.color;
                ctx.beginPath();
                for (let i = 0; i < 5; i++) {
                    ctx.rotate(Math.PI * 2 / 5); ctx.moveTo(0, 0);
                    ctx.bezierCurveTo(this.size / 2, -this.size / 2, this.size, 0, 0, this.size);
                }
                ctx.fill(); ctx.restore();
            }
        }

        function generateFlowerMatrix() {
            flowerArray = [];
            const targetedCount = Math.min(60, Math.floor(window.innerWidth / 25));
            for (let i = 0; i < targetedCount; i++) flowerArray.push(new CherryBlossomPetal());
        }
        generateFlowerMatrix();

        function structuralRenderAnimationLoop() {
            ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
            for (let i = 0; i < flowerArray.length; i++) { flowerArray[i].update(); flowerArray[i].draw(); }
            requestAnimationFrame(structuralRenderAnimationLoop);
        }
        structuralRenderAnimationLoop();


        // --- HYBRID DEVICES PARALLAX LAYER ENGINE ---
        const phoneModule = document.getElementById('phone-module');
        const pfpTiltNode = document.getElementById('pfp-tilt-node');
        const pfpImg = document.getElementById('pfp-img');
        let targetTiltX = 0, targetTiltY = 0, currentTiltX = 0, currentTiltY = 0;

        window.addEventListener('mousemove', (event) => {
            const normalizationX = (event.clientX / window.innerWidth) * 2 - 1;
            const normalizationY = (event.clientY / window.innerHeight) * 2 - 1;
            targetTiltX = normalizationX * 10; targetTiltY = -normalizationY * 10;
        });

        window.addEventListener('touchmove', (event) => {
            if(event.touches.length > 0) {
                const touchNode = event.touches[0];
                const normalizationX = (touchNode.clientX / window.innerWidth) * 2 - 1;
                const normalizationY = (touchNode.clientY / window.innerHeight) * 2 - 1;
                targetTiltX = normalizationX * 8; targetTiltY = -normalizationY * 8;
            }
        }, { passive: true });

        function smoothHardwareInterpolationLoop() {
            currentTiltX += (targetTiltX - currentTiltX) * 0.08;
            currentTiltY += (targetTiltY - currentTiltY) * 0.08;
            phoneModule.style.transform = `rotateY(${currentTiltX}deg) rotateX(${currentTiltY}deg)`;
            pfpTiltNode.style.transform = `rotateY(${currentTiltX * 0.5}deg) rotateX(${currentTiltY * 0.5}deg) translateZ(12px)`;
            pfpImg.style.transform = `scale(1.02) translateX(${-currentTiltX * 0.3}px) translateY(${currentTiltY * 0.3}px)`;
            requestAnimationFrame(smoothHardwareInterpolationLoop);
        }
        smoothHardwareInterpolationLoop();


        // --- LIVE DYNAMIC IMAGES CONVERT FACTORY ---
        function updateProfilePictureFrame(event) {
            const targetedImageFile = event.target.files[0];
            if (targetedImageFile) { pfpImg.src = URL.createObjectURL(targetedImageFile); }
        }

        function updateAlbumCoverArtwork(event) {
            const targetedImageFile = event.target.files[0];
            if (targetedImageFile) { document.getElementById('track-art-node').src = URL.createObjectURL(targetedImageFile); }
        }


        // --- DYNAMIC LIVE LINK BUILDER ENGINE ---
        function appendCustomSocialLinkElement() {
            const labelInput = document.getElementById('link-label-input');
            const urlInput = document.getElementById('link-url-input');
            const containerBlock = document.getElementById('social-container-block');
            const labelValue = labelInput.value.trim().toUpperCase();
            let urlValue = urlInput.value.trim();

            if (!labelValue || !urlValue) return;
            if (!/^https?:\/\//i.test(urlValue)) urlValue = 'https://' + urlValue;

            const anchorElement = document.createElement('a');
            anchorElement.href = urlValue; anchorElement.target = '_blank'; anchorElement.className = 'social-card';
            anchorElement.innerHTML = `<span>${labelValue}</span><span class="arrow-vector">➔</span>`;
            containerBlock.appendChild(anchorElement);
            
            labelInput.value = ''; urlInput.value = '';
            containerBlock.scrollTo({ top: containerBlock.scrollHeight, behavior: 'smooth' });
        }


        // --- AUDIO CONTROLLER CORES ---
        const gatewayShield = document.getElementById('gateway-shield');
        const audioEngine = document.getElementById('audio-media-core');
        const playSwitchNode = document.getElementById('play-switch-node');
        const playIconVector = document.getElementById('play-icon-vector');
        const avatarPulseNode = document.getElementById('avatar-pulse-node');
        const progressFillBar = document.getElementById('progress-fill-bar');
        const progressRail = document.getElementById('progress-rail');
        const elapsedTimer = document.getElementById('elapsed-time');
        const totalDurationTimer = document.getElementById('total-duration');
        const trackTitleNode = document.getElementById('track-title-node');
        const trackArtistNode = document.getElementById('track-artist-node');
        let isPlaying = false;

        function bootFluxxEnvironment() {
            gatewayShield.classList.add('fade-out');
            setTimeout(() => { phoneModule.classList.add('reveal'); }, 150);
            audioEngine.play().then(() => { applyActiveStatePlaybackMatrix(); }).catch(() => { applyHaltStatePlaybackMatrix(); });
        }

        function ingestCustomUserTrack(event) {
            const uploadedFile = event.target.files[0];
            if (!uploadedFile) return;
            audioEngine.src = URL.createObjectURL(uploadedFile);
            trackTitleNode.innerText = uploadedFile.name.replace(/\.[^/.]+$/, "");
            trackArtistNode.innerText = "Local Uploaded Asset";
            audioEngine.play().then(() => { applyActiveStatePlaybackMatrix(); });
        }

        function toggleAudioSystemEngine() {
            if (isPlaying) { audioEngine.pause(); applyHaltStatePlaybackMatrix(); }
            else { audioEngine.play().then(() => { applyActiveStatePlaybackMatrix(); }); }
        }

        function applyActiveStatePlaybackMatrix() {
            isPlaying = true; avatarPulseNode.classList.add('pulsing');
            playIconVector.innerHTML = `<path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>`;
        }

        function applyHaltStatePlaybackMatrix() {
            isPlaying = false; avatarPulseNode.classList.remove('pulsing');
            playIconVector.innerHTML = `<path d="M8 5v14l11-7z"/>`;
        }

        function shiftTrackDuration(seconds) { audioEngine.currentTime += seconds; }
        
        function seekAudioPlayback(event) {
            const railWidth = progressRail.clientWidth;
            const targetDurationPercentage = event.offsetX / railWidth;
            if (audioEngine.duration) audioEngine.currentTime = targetDurationPercentage * audioEngine.duration;
        }

        function formatDigitalAudioTimelineString(seconds) {
            if (isNaN(seconds)) return "0:00";
            const computedMinutes = Math.floor(seconds / 60);
            const computedSeconds = Math.floor(seconds % 60);
            return `${computedMinutes}:${computedSeconds < 10 ? '0' : ''}${computedSeconds}`;
        }

        audioEngine.addEventListener('timeupdate', () => {
            elapsedTimer.innerText = formatDigitalAudioTimelineString(audioEngine.currentTime);
            totalDurationTimer.innerText = formatDigitalAudioTimelineString(audioEngine.duration || 0);
            if (audioEngine.duration > 0) {
                progressFillBar.style.width = `${(audioEngine.currentTime / audioEngine.duration) * 100}%`;
            }
        });
    </script>
</body>
</html>
